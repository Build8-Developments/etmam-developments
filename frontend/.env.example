# Development Environment Variables
# Copy this file to .env.local for local development

# Site URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Strapi URLs - Client-side (used in browser)
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_GRAPHQL_URL=http://localhost:1337/graphql

# Strapi URLs - Server-side (used in Next.js server/API routes)
STRAPI_API_URL=http://localhost:1337
STRAPI_GRAPHQL_URL=http://localhost:1337/graphql

# Strapi API Token (for authenticated requests - get from Strapi Admin → Settings → API Tokens)
NEXT_PUBLIC_STRAPI_API_TOKEN=your-api-token-here
STRAPI_API_TOKEN=your-api-token-here

# On-Demand Revalidation Secret (for Strapi webhooks - generate with: openssl rand -base64 32)
REVALIDATION_SECRET=your-revalidation-secret-here

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_DARK_MODE=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=false
