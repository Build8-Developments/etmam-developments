# Strapi Environment Variables
# Copy this file to .env and fill in your actual values

# Application Keys (comma-separated, generate with: openssl rand -base64 32)
APP_KEYS=generate-key-1,generate-key-2,generate-key-3,generate-key-4

# API Token Salt (generate with: openssl rand -hex 64)
API_TOKEN_SALT=generate-your-api-token-salt-here

# Admin JWT Secret (generate with: openssl rand -base64 32)
ADMIN_JWT_SECRET=generate-your-admin-jwt-secret

# JWT Secret (generate with: openssl rand -hex 64)
JWT_SECRET=generate-your-jwt-secret-here

# Transfer Token Salt (generate with: openssl rand -hex 64)
TRANSFER_TOKEN_SALT=generate-your-transfer-token-salt

# Encryption Key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=generate-your-encryption-key

# Server Configuration
HOST=0.0.0.0
PORT=1337

# Database Configuration (optional - defaults to SQLite)
# For PostgreSQL:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=your-database-password
# DATABASE_SSL=false

# API Token (for seeding scripts - get from Strapi Admin → Settings → API Tokens)
STRAPI_API_TOKEN=your-api-token-here
STRAPI_URL=http://localhost:1337

# Frontend Revalidation (for webhooks to trigger Next.js cache invalidation)
FRONTEND_URL=http://localhost:3000
REVALIDATION_SECRET=your-revalidation-secret-here
